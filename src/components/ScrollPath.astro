---
/**
 * ScrollPath.astro
 * A decorative SVG path that "draws" as the user scrolls down the page.
 * Hidden on mobile (<1024px). Respects prefers-reduced-motion.
 */
---

<div class="scroll-path-container" aria-hidden="true">
  <svg
    id="scroll-path-svg"
    class="scroll-path-svg"
    viewBox="0 0 200 3000"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="none"
  >
    <!-- Main thread path — curves near each section anchor -->
    <path
      id="scroll-thread"
      d="
        M 100 0
        C 100 100, 160 150, 160 250
        S 40 350, 40 500
        C 40 600, 170 650, 170 800
        S 30 950, 30 1100
        C 30 1200, 150 1250, 150 1400
        S 50 1550, 50 1700
        C 50 1800, 160 1850, 160 2000
        S 40 2150, 40 2300
        C 40 2400, 130 2500, 130 2600
        S 100 2800, 100 3000
      "
      stroke="var(--color-accent)"
      stroke-width="1.5"
      stroke-linecap="round"
      opacity="0.15"
    />
    <!-- Glow duplicate for depth -->
    <path
      id="scroll-thread-glow"
      d="
        M 100 0
        C 100 100, 160 150, 160 250
        S 40 350, 40 500
        C 40 600, 170 650, 170 800
        S 30 950, 30 1100
        C 30 1200, 150 1250, 150 1400
        S 50 1550, 50 1700
        C 50 1800, 160 1850, 160 2000
        S 40 2150, 40 2300
        C 40 2400, 130 2500, 130 2600
        S 100 2800, 100 3000
      "
      stroke="var(--color-accent)"
      stroke-width="4"
      stroke-linecap="round"
      opacity="0.04"
    />
  </svg>
</div>

<style>
  .scroll-path-container {
    position: fixed;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 200px;
    height: 100vh;
    pointer-events: none;
    z-index: 0;
    overflow: visible;
  }

  .scroll-path-svg {
    width: 100%;
    height: 100%;
  }

  /* Hidden on mobile + tablet */
  @media (max-width: 1024px) {
    .scroll-path-container {
      display: none;
    }
  }

  /* Respect reduced motion — show path fully drawn, no animation */
  @media (prefers-reduced-motion: reduce) {
    #scroll-thread,
    #scroll-thread-glow {
      stroke-dasharray: none !important;
      stroke-dashoffset: 0 !important;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function getPageHeight(): number {
    return Math.max(
      document.body.scrollHeight,
      document.documentElement.scrollHeight,
      document.body.offsetHeight,
      document.documentElement.offsetHeight
    );
  }

  function buildPathD(h: number): string {
    // Generates a flowing S-curve path from top (y=0) to bottom (y=h)
    const seg = h / 10; // 10 segments
    return [
      `M 100 0`,
      `C 100 ${seg * 0.8}, 160 ${seg * 1.2}, 160 ${seg * 2}`,
      `S 40 ${seg * 3}, 40 ${seg * 4}`,
      `C 40 ${seg * 4.8}, 170 ${seg * 5.2}, 170 ${seg * 6}`,
      `S 30 ${seg * 7}, 30 ${seg * 8}`,
      `C 30 ${seg * 8.5}, 150 ${seg * 8.8}, 150 ${seg * 9}`,
      `S 100 ${seg * 9.7}, 100 ${h}`,
    ].join(' ');
  }

  function initScrollPath() {
    const prefersReducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;
    if (prefersReducedMotion) return;

    const svg = document.getElementById('scroll-path-svg') as SVGSVGElement | null;
    const path = document.getElementById('scroll-thread') as SVGPathElement | null;
    const glow = document.getElementById('scroll-thread-glow') as SVGPathElement | null;
    if (!svg || !path) return;

    function setup() {
      const h = getPageHeight();

      // Update viewBox to match real page height
      svg!.setAttribute('viewBox', `0 0 200 ${h}`);

      // Regenerate path shapes
      const d = buildPathD(h);
      path!.setAttribute('d', d);
      if (glow) glow.setAttribute('d', d);

      // Reset dasharray/offset
      const length = path!.getTotalLength();
      path!.style.strokeDasharray = `${length}`;
      path!.style.strokeDashoffset = `${length}`;

      if (glow) {
        const glowLength = glow.getTotalLength();
        glow.style.strokeDasharray = `${glowLength}`;
        glow.style.strokeDashoffset = `${glowLength}`;
      }

      // Kill existing ScrollTrigger instances for scroll-path to re-create
      ScrollTrigger.getAll()
        .filter(st => (st as any)._id?.toString().includes('scroll-path'))
        .forEach(st => st.kill());

      gsap.to(path, {
        strokeDashoffset: 0,
        ease: 'none',
        scrollTrigger: {
          id: 'scroll-path-main',
          trigger: document.body,
          start: 'top top',
          end: 'bottom bottom',
          scrub: 1,
        },
      });

      if (glow) {
        gsap.to(glow, {
          strokeDashoffset: 0,
          ease: 'none',
          scrollTrigger: {
            id: 'scroll-path-glow',
            trigger: document.body,
            start: 'top top',
            end: 'bottom bottom',
            scrub: 1.5,
          },
        });
      }

      ScrollTrigger.refresh();
    }

    // Initial setup after fonts/images settle
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => setTimeout(setup, 100));
    } else {
      setTimeout(setup, 100);
    }

    // Re-run on resize (debounced)
    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(setup, 300);
    });
  }

  initScrollPath();
</script>

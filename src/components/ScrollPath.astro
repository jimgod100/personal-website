---
/**
 * ScrollPath.astro
 * A decorative SVG path that "draws" as the user scrolls down the page.
 * Hidden on mobile (<1024px). Respects prefers-reduced-motion.
 */
---

<div class="scroll-path-container" aria-hidden="true">
  <svg
    class="scroll-path-svg"
    viewBox="0 0 200 3000"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="none"
  >
    <!-- Main thread path — curves near each section anchor -->
    <path
      id="scroll-thread"
      d="
        M 100 0
        C 100 100, 160 150, 160 250
        S 40 350, 40 500
        C 40 600, 170 650, 170 800
        S 30 950, 30 1100
        C 30 1200, 150 1250, 150 1400
        S 50 1550, 50 1700
        C 50 1800, 160 1850, 160 2000
        S 40 2150, 40 2300
        C 40 2400, 130 2500, 130 2600
        S 100 2800, 100 3000
      "
      stroke="var(--color-accent)"
      stroke-width="1.5"
      stroke-linecap="round"
      opacity="0.15"
    />
    <!-- Glow duplicate for depth -->
    <path
      id="scroll-thread-glow"
      d="
        M 100 0
        C 100 100, 160 150, 160 250
        S 40 350, 40 500
        C 40 600, 170 650, 170 800
        S 30 950, 30 1100
        C 30 1200, 150 1250, 150 1400
        S 50 1550, 50 1700
        C 50 1800, 160 1850, 160 2000
        S 40 2150, 40 2300
        C 40 2400, 130 2500, 130 2600
        S 100 2800, 100 3000
      "
      stroke="var(--color-accent)"
      stroke-width="4"
      stroke-linecap="round"
      opacity="0.04"
    />
  </svg>
</div>

<style>
  .scroll-path-container {
    position: fixed;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 200px;
    height: 100vh;
    pointer-events: none;
    z-index: 0;
    overflow: visible;
  }

  .scroll-path-svg {
    width: 100%;
    height: 100%;
  }

  /* Hidden on mobile + tablet */
  @media (max-width: 1024px) {
    .scroll-path-container {
      display: none;
    }
  }

  /* Respect reduced motion — show path fully drawn, no animation */
  @media (prefers-reduced-motion: reduce) {
    #scroll-thread,
    #scroll-thread-glow {
      stroke-dasharray: none !important;
      stroke-dashoffset: 0 !important;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initScrollPath() {
    const prefersReducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;
    if (prefersReducedMotion) return;

    const path = document.getElementById('scroll-thread') as SVGPathElement | null;
    const glow = document.getElementById('scroll-thread-glow') as SVGPathElement | null;
    if (!path) return;

    // getTotalLength must be called after DOM mount
    const length = path.getTotalLength();

    // Start: fully hidden (offset = length)
    path.style.strokeDasharray = `${length}`;
    path.style.strokeDashoffset = `${length}`;

    if (glow) {
      const glowLength = glow.getTotalLength();
      glow.style.strokeDasharray = `${glowLength}`;
      glow.style.strokeDashoffset = `${glowLength}`;
    }

    // Animate: draw the path over the entire page scroll
    gsap.to(path, {
      strokeDashoffset: 0,
      ease: 'none',
      scrollTrigger: {
        trigger: document.body,
        start: 'top top',
        end: 'bottom bottom',
        scrub: 1,
      },
    });

    if (glow) {
      gsap.to(glow, {
        strokeDashoffset: 0,
        ease: 'none',
        scrollTrigger: {
          trigger: document.body,
          start: 'top top',
          end: 'bottom bottom',
          scrub: 1.5,
        },
      });
    }
  }

  // Wait for DOM to be fully ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollPath);
  } else {
    initScrollPath();
  }
</script>

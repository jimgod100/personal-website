---
import { site } from '../data/site';
import HeroCanvas from './HeroCanvas';
---

<section class="hero" id="hero" aria-label="Introduction">
  <!-- WebGL particle background (React island) -->
  <div class="hero__canvas-wrap">
    <HeroCanvas client:only="react" />
  </div>

  <div class="container hero__inner">
    <!-- Text Side -->
    <div class="hero__content" data-motion-stagger-group="hero">
      <p class="hero__eyebrow" data-motion="fade-up">
        <span class="hero__eyebrow-dot" aria-hidden="true"></span>
        {site.location}
      </p>

      <h1 class="hero__headline" data-motion="fade-up">{site.hero.headline}</h1>

      <p class="hero__subheadline" data-motion="fade-up">{site.hero.subheadline}</p>

      <div class="hero__ctas" data-motion="fade-up">
        <a
          href={site.hero.primaryCta.href}
          class="btn btn--primary"
          id="hero-cta-primary"
        >
          {site.hero.primaryCta.label}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="btn__icon" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 0 1 0-1.06L9.44 9.5 5.22 5.28a.75.75 0 0 1 1.06-1.06l4.75 4.75a.75.75 0 0 1 0 1.06l-4.75 4.75a.75.75 0 0 1-1.06 0Z" clip-rule="evenodd" />
          </svg>
        </a>
        <a
          href={site.hero.secondaryCta.href}
          class="btn btn--secondary"
          id="hero-cta-resume"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="btn__icon btn__icon--left" aria-hidden="true">
            <path d="M10.75 2.75a.75.75 0 0 0-1.5 0v8.614L6.295 8.235a.75.75 0 1 0-1.09 1.03l4.25 4.5a.75.75 0 0 0 1.09 0l4.25-4.5a.75.75 0 0 0-1.09-1.03l-2.955 3.129V2.75Z" />
            <path d="M3.5 12.75a.75.75 0 0 0-1.5 0v2.5A2.75 2.75 0 0 0 4.75 18h10.5A2.75 2.75 0 0 0 18 15.25v-2.5a.75.75 0 0 0-1.5 0v2.5c0 .69-.56 1.25-1.25 1.25H4.75c-.69 0-1.25-.56-1.25-1.25v-2.5Z" />
          </svg>
          {site.hero.secondaryCta.label}
        </a>
      </div>

      {(site.hero as any).meta && (
        <p class="hero__meta" data-motion="fade-up">{(site.hero as any).meta}</p>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: var(--nav-height);
    background: var(--color-bg);
    position: relative;
    overflow: hidden;
  }

  /* Subtle grid background */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--color-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-border) 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.4;
    pointer-events: none;
    z-index: 0;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 60% at 70% 50%, transparent 40%, var(--color-bg) 100%);
    pointer-events: none;
    z-index: 1;
  }

  /* WebGL canvas wrapper */
  .hero__canvas-wrap {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
    position: relative;
    z-index: 2;
    min-height: calc(100svh - var(--nav-height));
  }

  .hero__content {
    max-width: 620px;
  }

  .hero__eyebrow {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    margin-bottom: var(--space-6);
  }

  .hero__eyebrow-dot {
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    border-radius: var(--radius-full);
    animation: pulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.85); }
  }

  .hero__headline {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin-bottom: var(--space-6);
  }

  .hero__subheadline {
    font-size: clamp(var(--text-base), 1.5vw, var(--text-lg));
    line-height: var(--leading-relaxed);
    color: var(--color-text-subtle);
    margin-bottom: var(--space-10);
    max-width: 52ch;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  .hero__meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .hero__content {
      max-width: 100%;
    }
  }

  @media (max-width: 480px) {
    .hero__headline {
      font-size: var(--text-2xl);
    }

    .hero__ctas {
      flex-direction: column;
    }
  }
</style>

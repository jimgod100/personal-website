---
import { site } from '../data/site';
---

<section class="hero" id="hero" aria-label="Introduction">
  <div class="container hero__inner">
    <!-- Text Side -->
    <div class="hero__content">
      <p class="hero__eyebrow">
        <span class="hero__eyebrow-dot" aria-hidden="true"></span>
        {site.location}
      </p>

      <h1 class="hero__headline">{site.hero.headline}</h1>

      <p class="hero__subheadline">{site.hero.subheadline}</p>

      <div class="hero__ctas">
        <a
          href={site.hero.primaryCta.href}
          class="btn btn--primary"
          id="hero-cta-primary"
        >
          {site.hero.primaryCta.label}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="btn__icon" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 0 1 0-1.06L9.44 9.5 5.22 5.28a.75.75 0 0 1 1.06-1.06l4.75 4.75a.75.75 0 0 1 0 1.06l-4.75 4.75a.75.75 0 0 1-1.06 0Z" clip-rule="evenodd" />
          </svg>
        </a>
        <a
          href={site.hero.secondaryCta.href}
          class="btn btn--secondary"
          id="hero-cta-resume"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="btn__icon btn__icon--left" aria-hidden="true">
            <path d="M10.75 2.75a.75.75 0 0 0-1.5 0v8.614L6.295 8.235a.75.75 0 1 0-1.09 1.03l4.25 4.5a.75.75 0 0 0 1.09 0l4.25-4.5a.75.75 0 0 0-1.09-1.03l-2.955 3.129V2.75Z" />
            <path d="M3.5 12.75a.75.75 0 0 0-1.5 0v2.5A2.75 2.75 0 0 0 4.75 18h10.5A2.75 2.75 0 0 0 18 15.25v-2.5a.75.75 0 0 0-1.5 0v2.5c0 .69-.56 1.25-1.25 1.25H4.75c-.69 0-1.25-.56-1.25-1.25v-2.5Z" />
          </svg>
          {site.hero.secondaryCta.label}
        </a>
      </div>

      <p class="hero__meta">{site.hero.meta}</p>
    </div>

    <!-- Visual Side -->
    <div class="hero__visual" aria-hidden="true">
      <div class="hero__visual-frame">
        <!-- Decorative geometric SVG — placeholder for future WebGL canvas -->
        <svg class="hero__geometry" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
          <!-- Outer ring -->
          <circle cx="200" cy="200" r="160" fill="none" stroke="var(--color-accent)" stroke-width="1" stroke-dasharray="6 10" opacity="0.3" />
          <!-- Middle ring -->
          <circle cx="200" cy="200" r="110" fill="none" stroke="var(--color-accent)" stroke-width="1" opacity="0.2" />
          <!-- Inner ring -->
          <circle cx="200" cy="200" r="60" fill="none" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.4" />
          <!-- Core dot -->
          <circle cx="200" cy="200" r="8" fill="var(--color-accent)" opacity="0.8" />
          <!-- Grid lines -->
          <line x1="40" y1="200" x2="360" y2="200" stroke="var(--color-border)" stroke-width="1" />
          <line x1="200" y1="40" x2="200" y2="360" stroke="var(--color-border)" stroke-width="1" />
          <!-- Corner marks -->
          <path d="M40 60 L40 40 L60 40" fill="none" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.5" />
          <path d="M340 60 L360 60 L360 40 L340 40" fill="none" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.5" />
          <path d="M40 340 L40 360 L60 360" fill="none" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.5" />
          <path d="M340 340 L360 340 L360 360 L340 360" fill="none" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.5" />
          <!-- Orbital dots -->
          <circle cx="200" cy="40" r="4" fill="var(--color-accent)" opacity="0.6" />
          <circle cx="360" cy="200" r="4" fill="var(--color-accent)" opacity="0.4" />
          <circle cx="200" cy="360" r="4" fill="var(--color-accent)" opacity="0.3" />
          <circle cx="88" cy="112" r="3" fill="var(--color-accent)" opacity="0.5" />
          <circle cx="312" cy="88" r="3" fill="var(--color-accent)" opacity="0.35" />
          <!-- Diagonal accent -->
          <line x1="90" y1="90" x2="310" y2="310" stroke="var(--color-accent)" stroke-width="1" stroke-dasharray="4 8" opacity="0.15" />
          <line x1="310" y1="90" x2="90" y2="310" stroke="var(--color-accent)" stroke-width="1" stroke-dasharray="4 8" opacity="0.15" />
        </svg>
        <!-- Badge overlay -->
        <div class="hero__badge">
          <span class="hero__badge-label">v0</span>
          <span class="hero__badge-sub">WebGL ready</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: var(--nav-height);
    background: var(--color-bg);
    position: relative;
    overflow: hidden;
  }

  /* Subtle grid background */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--color-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-border) 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.4;
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 60% at 70% 50%, transparent 40%, var(--color-bg) 100%);
    pointer-events: none;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: var(--space-16);
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
    position: relative;
    z-index: 1;
  }

  .hero__content {
    max-width: 580px;
  }

  .hero__eyebrow {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    margin-bottom: var(--space-6);
  }

  .hero__eyebrow-dot {
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    border-radius: var(--radius-full);
    animation: pulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.85); }
  }

  .hero__headline {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin-bottom: var(--space-6);
  }

  .hero__subheadline {
    font-size: clamp(var(--text-base), 1.5vw, var(--text-lg));
    line-height: var(--leading-relaxed);
    color: var(--color-text-subtle);
    margin-bottom: var(--space-10);
    max-width: 52ch;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  .hero__meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  /* Visual */
  .hero__visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__visual-frame {
    position: relative;
    width: min(400px, 100%);
    aspect-ratio: 1;
  }

  .hero__geometry {
    width: 100%;
    height: 100%;
    animation: slow-rotate 60s linear infinite;
  }

  @keyframes slow-rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .hero__badge {
    position: absolute;
    bottom: 12%;
    right: 8%;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-4);
    box-shadow: var(--shadow-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .hero__badge-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: var(--color-accent);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
  }

  .hero__badge-sub {
    font-size: 10px;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }

    .hero__visual {
      order: -1;
    }

    .hero__visual-frame {
      width: min(280px, 80%);
    }

    .hero__content {
      max-width: 100%;
    }
  }

  @media (max-width: 480px) {
    .hero__headline {
      font-size: var(--text-2xl);
    }

    .hero__ctas {
      flex-direction: column;
    }

    .hero__visual-frame {
      width: min(240px, 90%);
    }
  }
</style>

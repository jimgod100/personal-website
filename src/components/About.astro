---
import { site } from '../data/site';
import SectionHeading from './SectionHeading.astro';
---

<section class="about section" id="about" aria-label="About">
  <div class="container about__inner">
    <SectionHeading label="About">
      <h2 class="section-title">A bit about me</h2>
    </SectionHeading>

    <div class="about__content">
      <div class="about__text">
        {site.about.map((paragraph, i) => (
          <p class={`about__paragraph ${i === 0 ? 'about__paragraph--lead' : ''}`}>
            {paragraph}
          </p>
        ))}
      </div>

      <aside class="about__sidebar">
        <div class="about__card">
          <div class="about__card-row">
            <span class="about__card-label">Location</span>
            <span class="about__card-value">{site.location}</span>
          </div>
          <div class="about__card-row">
            <span class="about__card-label">Role</span>
            <span class="about__card-value">Software Engineer</span>
          </div>
          <div class="about__card-row">
            <span class="about__card-label">Status</span>
            <span class="about__card-value">
              <span class="status-dot" aria-hidden="true"></span>
              Open to opportunities
            </span>
          </div>
          <div class="about__card-divider"></div>
          <div class="about__card-links">
            <a
              href={site.github}
              class="about__card-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub profile"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="about__card-link-icon" aria-hidden="true">
                <path d="M12 0C5.373 0 0 5.373 0 12c0 5.303 3.438 9.8 8.207 11.387.6.11.793-.26.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.729.083-.729 1.205.085 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12Z"/>
              </svg>
              GitHub
            </a>
            <a
              href={site.linkedin}
              class="about__card-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn profile"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="about__card-link-icon" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .about {
    background: var(--color-bg-subtle);
  }

  .about__inner {
  }

  .about__content {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--space-16);
    align-items: start;
  }

  .about__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .about__paragraph {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-subtle);
  }

  .about__paragraph--lead {
    font-size: var(--text-lg);
    color: var(--color-text);
    font-weight: var(--weight-medium);
  }

  /* Sidebar card */
  .about__card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    box-shadow: var(--shadow-card);
  }

  .about__card-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border);
    gap: var(--space-4);
  }

  .about__card-row:first-child {
    padding-top: 0;
  }

  .about__card-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .about__card-value {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text);
    text-align: right;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .status-dot {
    width: 7px;
    height: 7px;
    background: #22c55e;
    border-radius: var(--radius-full);
    flex-shrink: 0;
    animation: pulse-green 2s ease-in-out infinite;
  }

  @keyframes pulse-green {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4); }
    50% { opacity: 0.8; box-shadow: 0 0 0 4px rgba(34, 197, 94, 0); }
  }

  .about__card-divider {
    height: 1px;
    background: var(--color-border);
    margin: var(--space-4) 0;
  }

  .about__card-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .about__card-link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-subtle);
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .about__card-link:hover {
    color: var(--color-accent);
    background: var(--color-accent-subtle);
  }

  .about__card-link-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .about__content {
      grid-template-columns: 1fr;
    }

    .about__sidebar {
      order: -1;
    }
  }
</style>

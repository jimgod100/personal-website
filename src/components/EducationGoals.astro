---
import { site } from '../data/site';
import SectionHeading from './SectionHeading.astro';
---

<section class="edu-goals section" id="education" aria-label="Education and Goals">
  <div class="container">
    <SectionHeading label="Education & Goals">
      <h2 class="section-title">{site.goals.headline}</h2>
    </SectionHeading>

    <div class="edu-goals__content">
      <div class="edu-goals__main">
        <div class="edu-goals__card">
          <div class="edu-goals__icon-wrap" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="edu-goals__icon">
              <path d="M12 14l9-5-9-5-9 5 9 5z"/>
              <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"/>
            </svg>
          </div>
          <div class="edu-goals__text">
            <h3 class="edu-goals__card-title">Graduate Studies</h3>
            <p class="edu-goals__body">{site.goals.body}</p>
          </div>
        </div>

        <div class="edu-goals__focus-areas">
          <h3 class="edu-goals__focus-title">Focus Areas</h3>
          <div class="edu-goals__tags">
            <span class="edu-goals__tag">Computer Science Fundamentals</span>
            <span class="edu-goals__tag">Applied AI & ML</span>
            <span class="edu-goals__tag">Distributed Systems</span>
            <span class="edu-goals__tag">Systems Programming</span>
            <span class="edu-goals__tag">Global Tech Industry</span>
          </div>
        </div>
      </div>

      <aside class="edu-goals__sidebar">
        <div class="edu-goals__open-to">
          <p class="edu-goals__open-to-label">
            <span class="status-dot" aria-hidden="true"></span>
            Currently open to
          </p>
          <p class="edu-goals__open-to-text">{site.openTo}</p>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .edu-goals {
    background: var(--color-bg-subtle);
  }

  .edu-goals__content {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-8);
    align-items: start;
  }

  .edu-goals__main {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .edu-goals__card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    display: flex;
    gap: var(--space-6);
    box-shadow: var(--shadow-card);
  }

  .edu-goals__icon-wrap {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    background: var(--color-accent-subtle);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
  }

  .edu-goals__icon {
    width: 24px;
    height: 24px;
  }

  .edu-goals__text {
    flex: 1;
  }

  .edu-goals__card-title {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .edu-goals__body {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-subtle);
  }

  .edu-goals__focus-areas {
  }

  .edu-goals__focus-title {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    font-weight: var(--weight-semibold);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    margin-bottom: var(--space-4);
  }

  .edu-goals__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .edu-goals__tag {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background: var(--color-bg-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-subtle);
  }

  /* Sidebar */
  .edu-goals__open-to {
    background: var(--color-surface);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    box-shadow: 0 0 0 4px var(--color-accent-subtle);
  }

  .edu-goals__open-to-label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--color-accent);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    margin-bottom: var(--space-3);
  }

  .status-dot {
    width: 7px;
    height: 7px;
    background: #22c55e;
    border-radius: var(--radius-full);
    flex-shrink: 0;
    animation: pulse-green 2s ease-in-out infinite;
  }

  @keyframes pulse-green {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4); }
    50% { opacity: 0.8; box-shadow: 0 0 0 4px rgba(34, 197, 94, 0); }
  }

  .edu-goals__open-to-text {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text-subtle);
  }

  @media (max-width: 900px) {
    .edu-goals__content {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .edu-goals__card {
      flex-direction: column;
      gap: var(--space-4);
      padding: var(--space-6);
    }
  }
</style>

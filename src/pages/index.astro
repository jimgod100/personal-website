---
import Layout from '../components/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Experience from '../components/Experience.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import Skills from '../components/Skills.astro';
import EducationGoals from '../components/EducationGoals.astro';
import Contact from '../components/Contact.astro';
import ScrollPath from '../components/ScrollPath.astro';
import { site } from '../data/site';
---

<Layout title={site.title} description={site.description}>
  <Nav />
  <ScrollPath />
  <main id="main-content">
    <div class="parallax-layer" style="--parallax-speed: 0;">
      <Hero />
    </div>
    <div class="parallax-layer" style="--parallax-speed: 0.1;">
      <About />
    </div>
    <div class="parallax-layer" style="--parallax-speed: 0.15;">
      <Experience />
    </div>
    <div class="parallax-layer" style="--parallax-speed: 0.2;">
      <ProjectGrid />
    </div>
    <div class="parallax-layer" style="--parallax-speed: 0.25;">
      <Skills />
    </div>
    <div class="parallax-layer" style="--parallax-speed: 0.3;">
      <EducationGoals />
    </div>
    <div class="parallax-layer" style="--parallax-speed: 0.1;">
      <Contact />
    </div>
  </main>
  <footer class="footer">
    <div class="container footer__inner">
      <p class="footer__copy">
        &copy; {new Date().getFullYear()} {site.name}. Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>.
      </p>
      <p class="footer__note">v1 — Lusion-inspired</p>
    </div>
  </footer>
</Layout>

<style>
  .footer {
    padding: var(--space-8) 0;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .footer__copy {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .footer__copy a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .footer__copy a:hover {
    text-decoration: underline;
  }

  .footer__note {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  @media (max-width: 480px) {
    .footer__inner {
      flex-direction: column;
      text-align: center;
      gap: var(--space-2);
    }
  }
</style>

<script>
  // Intersection Observer for lightweight scroll reveals
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.3 }
  );

  document.querySelectorAll('[data-motion]').forEach((el) => {
    observer.observe(el);
  });

  // Parallax effect for HTML sections
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  
  if (!prefersReducedMotion) {
    const layers = document.querySelectorAll<HTMLElement>('.parallax-layer');
    const skewElements = document.querySelectorAll<HTMLElement>('.project-card, .about__card, .experience__item');

    let currentScroll = window.scrollY;
    let targetScroll = window.scrollY;

    function lerp(start: number, end: number, factor: number) {
      return start + (end - start) * factor;
    }

    function rafLoop() {
      targetScroll = window.scrollY;
      currentScroll = lerp(currentScroll, targetScroll, 0.1);
      
      const velocity = targetScroll - currentScroll;
      let normalizedV = Math.abs(velocity) / 50;
      normalizedV = Math.min(Math.max(normalizedV, 0), 1);
      const skewAngle = normalizedV * 1.5 * Math.sign(velocity); // Max 1.5 degrees

      layers.forEach(layer => {
        const speed = parseFloat(layer.style.getPropertyValue('--parallax-speed') || '0');
        if (speed !== 0) {
          layer.style.transform = `translateY(${targetScroll * speed * -1}px)`;
        }
      });

      skewElements.forEach(el => {
        // preserve other transforms if needed, but for these cards, overriding is okay
        el.style.transform = `skewY(${skewAngle}deg)`;
      });

      requestAnimationFrame(rafLoop);
    }
    
    requestAnimationFrame(rafLoop);
  }
</script>
